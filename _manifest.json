{
  "manifest_version": 2,
  "version": "0.4.0",
  "name": "A_Mind 智能话题管理插件",
  "description": "基于大模型的智能话题发起、追踪和回复插件，支持权限控制和自动状态管理",
  "author": {
    "name": "A-Dawn",
    "url": "https://github.com/A-Dawn"
  },
  "license": "AGPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/A-Dawn/A_Mind",
    "homepage": "https://github.com/A-Dawn/A_Mind",
    "documentation": "https://github.com/A-Dawn/A_Mind",
    "issues": "https://github.com/A-Dawn/A_Mind/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "toml",
      "version_spec": ">=0.10.2,<1.0.0"
    }
  ],
  "capabilities": [
    "send.text",
    "send.image",
    "send.emoji",
    "send.forward",
    "send.hybrid",
    "send.command",
    "send.custom",
    "llm.generate",
    "llm.generate_with_tools",
    "llm.get_available_models",
    "config.get",
    "config.get_plugin",
    "chat.get_all_streams",
    "chat.get_group_streams",
    "chat.get_private_streams",
    "tool.get_definitions"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "A-Dawn.A-Mind"
}
